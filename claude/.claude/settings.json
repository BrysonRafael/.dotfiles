{
  "permissions": {
    "allow": [
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(nvim:*)",
      "Bash(grep:*)",
      "Bash(gem list:*)",
      "Bash(bundle info:*)",
      "Read(//Users/brysonrafael/Code/**)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(nc *)",
      "Bash(netcat *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(sftp *)",
      "Bash(pco console *)",
      "Bash(pco connect *)",
      "Bash(pco dbconnect *)",
      "Bash(pco ssm *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.env.local)",
      "Read(.npmrc)",
      "Read(.bundle/config)",
      "Read(**/secrets/**)",
      "Read(**/.secrets/**)",
      "Read(**/credentials*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*_rsa)",
      "Read(**/*_dsa)",
      "Read(**/*_ecdsa)",
      "Read(**/*_ed25519)",
      "Read(**/.ssh/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(.env.local)",
      "Edit(.npmrc)",
      "Edit(.bundle/config)",
      "Edit(**/secrets/**)",
      "Edit(**/.secrets/**)",
      "Edit(**/credentials*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)"
    ],
    "ask": [
      "Bash(pco *)",
      "Bash(chmod *)",
      "Bash(git reset --hard )",
      "Bash(git clean -fd *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/devbox-enforce.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "coding-standards@planning-center": true,
    "redshift-mcp@planning-center": true,
    "slack@claude-plugins-official": true,
    "asana@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "tapestry@planning-center": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": true,
    "pr@planning-center": true,
    "lua-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "adversarial-review@planning-center": true,
    "asana-html-formatting@planning-center": true,
    "bugsnag@planning-center": true,
    "bugsnag-triage@planning-center": true,
    "claude-md-toolkit@planning-center": true,
    "datadog@planning-center": true,
    "flipper@planning-center": true,
    "pco-box@planning-center": true,
    "figma@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "model": "opus[1m]"
}
